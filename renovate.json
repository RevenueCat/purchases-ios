{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>RevenueCat/renovate"],
  "packageRules": [
    {
      "matchPackageNames": ["swift-package-manager-google-mobile-ads"],
      "matchManagers": ["swift"],
      "matchFileNames": ["Tuist/Package.swift", "AdapterSDKs/RevenueCatAdMob/Package.swift"],
      "enabled": true,
      "groupName": "google-mobile-ads"
    }
  ]
}
