{
  "fixtures": [
    {
      "id": "some_returns_true_when_all_items_match",
      "predicate": {
        "some": [
          [
            1,
            2,
            3
          ],
          {
            ">": [
              {
                "var": ""
              },
              0
            ]
          }
        ]
      },
      "variables": {},
      "expected": true
    },
    {
      "id": "some_returns_true_when_only_first_item_matches",
      "description": "order independence: a match in the first position is enough even when the rest fail",
      "predicate": {
        "some": [
          [
            1,
            -2,
            -3
          ],
          {
            ">": [
              {
                "var": ""
              },
              0
            ]
          }
        ]
      },
      "variables": {},
      "expected": true
    },
    {
      "id": "some_returns_true_when_only_middle_item_matches",
      "description": "order independence: a match in a middle position is enough even when the surrounding items fail",
      "predicate": {
        "some": [
          [
            -1,
            2,
            -3
          ],
          {
            ">": [
              {
                "var": ""
              },
              0
            ]
          }
        ]
      },
      "variables": {},
      "expected": true
    },
    {
      "id": "some_returns_false_when_no_item_matches",
      "predicate": {
        "some": [
          [
            -1,
            -2,
            -3
          ],
          {
            ">": [
              {
                "var": ""
              },
              0
            ]
          }
        ]
      },
      "variables": {},
      "expected": false
    },
    {
      "id": "some_returns_false_for_empty_array",
      "predicate": {
        "some": [
          [],
          {
            ">": [
              {
                "var": ""
              },
              0
            ]
          }
        ]
      },
      "variables": {},
      "expected": false
    },
    {
      "id": "some_returns_false_for_null_source",
      "predicate": {
        "some": [
          null,
          {
            ">": [
              {
                "var": ""
              },
              0
            ]
          }
        ]
      },
      "variables": {},
      "expected": false
    },
    {
      "id": "some_returns_false_for_object_source",
      "description": "multi-key objects are returned by the evaluator as literal data (single-key objects would dispatch as an operator), so the array check fails",
      "predicate": {
        "some": [
          {
            "foo": 1,
            "bar": 2
          },
          {
            ">": [
              {
                "var": ""
              },
              0
            ]
          }
        ]
      },
      "variables": {},
      "expected": false
    },
    {
      "id": "some_returns_false_for_string_source",
      "predicate": {
        "some": [
          "abc",
          {
            ">": [
              {
                "var": ""
              },
              0
            ]
          }
        ]
      },
      "variables": {},
      "expected": false
    },
    {
      "id": "some_predicate_sees_current_item_via_empty_var",
      "description": "{\"var\": \"\"} resolves to the current item",
      "predicate": {
        "some": [
          [
            false,
            true,
            false
          ],
          {
            "var": ""
          }
        ]
      },
      "variables": {},
      "expected": true
    },
    {
      "id": "some_predicate_accesses_item_fields",
      "description": "item objects are routed through vars so the evaluator does not dispatch their single key (status) as an operator",
      "predicate": {
        "some": [
          {
            "var": "items"
          },
          {
            "==": [
              {
                "var": "status"
              },
              "active"
            ]
          }
        ]
      },
      "variables": {
        "items": [
          {
            "status": "expired"
          },
          {
            "status": "active"
          }
        ]
      },
      "expected": true
    },
    {
      "id": "some_missing_predicate_returns_false",
      "description": "a missing predicate evaluates to undefined per item (never truthy), so an array source returns false",
      "predicate": {
        "some": [
          [
            1,
            2
          ]
        ]
      },
      "variables": {},
      "expected": false
    },
    {
      "id": "some_predicate_cannot_reach_parent_scope",
      "description": "inside the predicate only the current item is visible; outer x is unreachable so {\"var\": \"x\"} resolves to null and equality is false for every item",
      "predicate": {
        "some": [
          [
            {},
            {}
          ],
          {
            "==": [
              {
                "var": "x"
              },
              "outer"
            ]
          }
        ]
      },
      "variables": {
        "x": "outer"
      },
      "expected": false
    },
    {
      "id": "some_returns_true_when_one_object_in_array_matches",
      "description": "object array source where at least one item satisfies the predicate returns true",
      "predicate": {
        "some": [
          {
            "var": "subscriptions"
          },
          {
            "==": [
              {
                "var": "status"
              },
              "active"
            ]
          }
        ]
      },
      "variables": {
        "subscriptions": [
          {
            "status": "active"
          },
          {
            "status": "active"
          },
          {
            "status": "trialing"
          }
        ]
      },
      "expected": true
    },
    {
      "id": "some_returns_false_when_no_object_in_array_matches",
      "description": "object array source where no item satisfies the predicate returns false",
      "predicate": {
        "some": [
          {
            "var": "subscriptions"
          },
          {
            "==": [
              {
                "var": "status"
              },
              "active"
            ]
          }
        ]
      },
      "variables": {
        "subscriptions": [
          {
            "status": "expired"
          },
          {
            "status": "expired"
          },
          {
            "status": "expired"
          }
        ]
      },
      "expected": false
    },
    {
      "id": "some_with_literal_true_predicate_returns_true",
      "description": "a non-logic literal predicate is returned as-is per item; a truthy literal makes a non-empty source return true",
      "predicate": {
        "some": [
          [
            1,
            2
          ],
          true
        ]
      },
      "variables": {},
      "expected": true
    },
    {
      "id": "some_with_non_boolean_truthy_predicate_result",
      "description": "predicate results go through JSON Logic truthiness, not a strict boolean check: 0 is falsy and a non-zero number is truthy",
      "predicate": {
        "some": [
          {
            "var": "items"
          },
          {
            "var": "count"
          }
        ]
      },
      "variables": {
        "items": [
          {
            "count": 0
          },
          {
            "count": 3
          }
        ]
      },
      "expected": true
    }
  ]
}
