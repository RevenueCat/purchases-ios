{
  "fixtures": [
    {
      "id": "min_returns_smallest_of_many_args",
      "predicate": {
        "===": [
          {
            "min": [
              1,
              2,
              3
            ]
          },
          1
        ]
      },
      "variables": {},
      "expected": true
    },
    {
      "id": "min_single_arg_returns_value",
      "predicate": {
        "===": [
          {
            "min": [
              7
            ]
          },
          7
        ]
      },
      "variables": {},
      "expected": true
    },
    {
