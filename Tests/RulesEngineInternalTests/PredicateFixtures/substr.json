    {
      "id": "substr_negative_infinite_length_returns_empty",
      "description": "-Infinity length clamps to 0, giving an empty result",
      "predicate": { "===": [{ "substr": ["abcd", 1, { "var": "-Infinity" }] }, ""] },
      "variables": {},
      "expected": true
