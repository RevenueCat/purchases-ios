    {
      "id": "substr_negative_length_drops_from_right",
      "description": "step 1: \"hello\".substr(1) = \"ello\"; step 2: \"ello\".substr(0, len(\"ello\") + (-2)) = \"el\"",
      "predicate": { "===": [{ "substr": ["hello", 1, -2] }, "el"] },
      "variables": {},
      "expected": true
    },
    {
      "id": "substr_start_past_end_returns_empty",
