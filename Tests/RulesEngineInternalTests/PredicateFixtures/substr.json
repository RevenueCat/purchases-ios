    {
      "id": "substr_nan_length_treats_as_zero",
      "description": "NaN length coerces to 0, giving an empty result; NaN is produced via division-by-zero since JSON has no NaN literal",
      "predicate": { "===": [{ "substr": ["abcd", 0, { "/": [0, 0] }] }, ""] },
