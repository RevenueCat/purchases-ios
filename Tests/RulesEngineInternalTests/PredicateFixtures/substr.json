      "variables": {},
      "expected": true
    },
    {
      "id": "substr_three_args_extracts_fixed_length",
      "predicate": { "===": [{ "substr": ["hello", 1, 3] }, "ell"] },
      "variables": {},
      "expected": true
    },
    {
      "id": "substr_negative_start_counts_from_end",
