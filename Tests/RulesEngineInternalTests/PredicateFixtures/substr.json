      "description": "multibyte UTF-8: \"café\" is 4 characters but 5 bytes; slicing from index 1 gives \"afé\"",
      "predicate": { "===": [{ "substr": ["café", 1] }, "afé"] },
      "variables": {},
      "expected": true
    },
    {
      "id": "substr_stringifies_non_string_source",
      "description": "source is coerced via stringify, so 12345 becomes \"12345\"",
