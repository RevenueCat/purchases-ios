      "variables": {},
      "expected": true
    },
    {
      "id": "substr_negative_start_clamped_to_zero",
      "description": "negative start beyond length clamps to the start of the string, returning the full string",
      "predicate": { "===": [{ "substr": ["abc", -10] }, "abc"] },
      "variables": {},
      "expected": true
    },
    {
      "id": "substr_length_exceeding_remaining_clamps",
      "predicate": { "===": [{ "substr": ["abc", 0, 100] }, "abc"] },
