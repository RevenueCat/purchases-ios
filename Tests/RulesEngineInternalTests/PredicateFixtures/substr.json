      "variables": {},
      "expected": true
    },
    {
      "id": "substr_negative_infinite_start_clamps_to_zero",
      "description": "-Infinity start clamps to 0, returning the whole string",
      "predicate": { "===": [{ "substr": ["abcd", { "var": "-Infinity" }] }, "abcd"] },
      "variables": {},
      "expected": true
    },
    {
      "id": "substr_oversized_start_clamps_to_total",
      "description": "a finite Double beyond Int.max clamps to total length, returning empty",
