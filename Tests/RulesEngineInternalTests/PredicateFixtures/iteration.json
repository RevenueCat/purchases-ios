      "id": "filter_missing_predicate_returns_empty_array",
      "description": "a missing predicate evaluates to null (falsy) per item, so filter retains nothing; compared by string coercion to the empty string",
      "predicate": { "==": [{ "filter": [[1, 2, 3]] }, ""] },
      "variables": {},
