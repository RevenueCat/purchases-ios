      "variables": {},
      "expected": true
    },
    {
      "id": "some_predicate_cannot_reach_parent_scope",
      "description": "inside the predicate only the current item is visible; outer x is unreachable so {\"var\": \"x\"} resolves to null and equality is false for every item",
      "predicate": {
        "some": [[{}, {}], { "==": [{ "var": "x" }, "outer"] }]
      },
      "variables": { "x": "outer" },
      "expected": false
    },
    {
      "id": "all_nested_some_inside_all_rebounds_item_scope",
      "description": "for every customer at least one product must be active; nested iteration rebinds the item scope at each level",
      "predicate": {
        "all": [
          { "var": "customers" },
          { "some": [{ "var": "products" }, { "==": [{ "var": "status" }, "active"] }] }
        ]
      },
      "variables": {
        "customers": [
          { "products": [{ "status": "expired" }, { "status": "active" }] },
          { "products": [{ "status": "active" }] }
        ]
      },
      "expected": true
    },
    {
      "id": "some_khepri_active_subscription_matching",
      "description": "mirrors khepri/some_active_subscription/matching to pin parity with the backend oracle",
      "predicate": {
        "some": [{ "var": "subscriptions" }, { "==": [{ "var": "status" }, "active"] }]
      },
      "variables": {
        "subscriptions": [
          { "status": "active" },
          { "status": "active" },
          { "status": "trialing" }
        ]
      },
      "expected": true
    },
