      "id": "filter_returns_empty_array_for_object_source",
      "description": "multi-key object is treated as literal data, so filter yields []; compared by string coercion to the empty string",
      "predicate": { "==": [{ "filter": [{ "foo": 1, "bar": 2 }, { ">": [{ "var": "" }, 0] }] }, ""] },
      "variables": {},
