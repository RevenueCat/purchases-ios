    {
      "id": "map_applies_predicate_to_each_item",
      "description": "map produces [2,4,6] (arithmetic widens to float); compared by JS string coercion since loose == is always false for array-vs-array",
      "predicate": {
        "==": [
          {
            "map": [
              [
                1,
                2,
                3
              ],
              {
                "*": [
                  {
                    "var": ""
                  },
                  2
                ]
              }
            ]
          },
          "2,4,6"
        ]
      },
      "variables": {},
      "expected": true
    },
    {
